# ARK Digitaler Kalender - Umgebungsvariablen

# OpenAI API Konfiguration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# Server Konfiguration
PORT=8000
NODE_ENV=development

# CORS Einstellungen
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# Spruch-Generierung
DEFAULT_QUOTE_LENGTH=medium
DEFAULT_THEME=Motivation
QUOTES_PER_DAY=1

# Benachrichtigungen
ENABLE_NOTIFICATIONS=true
DEFAULT_NOTIFICATION_TIME=09:00

# Datenbank (für zukünftige Erweiterungen)
DATABASE_URL=sqlite:./data/ark.db

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/ark.log

# Cache
CACHE_TTL=3600
ENABLE_CACHE=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Sicherheit
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here

# Features (experimentell)
ENABLE_AI_GENERATION=false
ENABLE_USER_ACCOUNTS=false
ENABLE_SOCIAL_FEATURES=false