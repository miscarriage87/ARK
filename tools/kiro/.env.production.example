# ARK Digital Calendar - Production Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://ark_user:your_secure_password@db:5432/ark_production
POSTGRES_USER=ark_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ark_production

# AI Service Configuration
OPENAI_API_KEY=your_production_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=150
OPENAI_TEMPERATURE=0.7

# Security Configuration
SECRET_KEY=your_256_bit_secret_key_here_minimum_32_characters
JWT_SECRET_KEY=your_jwt_secret_key_here_different_from_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Application Configuration
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=ARK Digital Calendar
APP_VERSION=1.0.0

# CORS Configuration
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://app.yourdomain.com

# Cache Configuration
REDIS_URL=redis://:your_redis_password@redis:6379/0
REDIS_PASSWORD=your_redis_password_here
CACHE_TTL=3600

# Monitoring and Logging
SENTRY_DSN=your_sentry_dsn_for_error_tracking
LOG_FILE=/app/logs/ark.log
METRICS_ENABLED=true

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=ark-backups-production
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Email Configuration (for notifications)
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your_smtp_password
SMTP_TLS=true

# Rate Limiting
RATE_LIMIT_QUOTE_GENERATION=10/minute
RATE_LIMIT_FEEDBACK=100/minute
RATE_LIMIT_PROFILE_UPDATE=20/minute
RATE_LIMIT_ARCHIVE_ACCESS=50/minute

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_DATA_EXPORT=true
ENABLE_ADMIN_PANEL=false

# Monitoring Passwords
GRAFANA_PASSWORD=your_grafana_admin_password
PROMETHEUS_PASSWORD=your_prometheus_password

# SSL Configuration (if using custom certificates)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Performance Configuration
WORKER_PROCESSES=4
MAX_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65
CLIENT_MAX_BODY_SIZE=16M

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Content Generation Limits
MAX_QUOTE_LENGTH=500
MIN_QUOTE_LENGTH=50
QUOTE_GENERATION_TIMEOUT=30

# User Limits
MAX_USERS_PER_IP=10
MAX_FEEDBACK_PER_DAY=100
MAX_PROFILE_UPDATES_PER_DAY=10

# Cleanup Configuration
CLEANUP_OLD_LOGS_DAYS=30
CLEANUP_TEMP_FILES_HOURS=24
CLEANUP_FAILED_JOBS_DAYS=7