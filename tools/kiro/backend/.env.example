# ARK Digital Calendar - Environment Configuration Example
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=sqlite:///./database/ark.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/ark_db

# Security
SECRET_KEY=your-secret-key-change-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Application Settings
APP_NAME=ARK Digital Calendar
DEBUG=False

# Push Notifications (VAPID keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CLAIMS_EMAIL=admin@arkapp.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# File Storage
UPLOAD_DIR=./uploads